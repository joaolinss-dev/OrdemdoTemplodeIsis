  <script src="https://unpkg.com/lenis@1.1.14/dist/lenis.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script>
    gsap.registerPlugin(ScrollTrigger);

    /* ── LOADING SCREEN ── */
    const loadingScreen = document.getElementById('loading-screen');
    const hideLoading = () => loadingScreen.classList.add('hidden');
    if (document.readyState === 'complete') {
      setTimeout(hideLoading, 2900);
    } else {
      window.addEventListener('load', () => setTimeout(hideLoading, 2900));
    }

    /* ── LENIS + GSAP ── */
    const savedAnimationPref = localStorage.getItem('otiAnimations');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let animationsEnabled = savedAnimationPref === null
      ? !prefersReducedMotion
      : savedAnimationPref === 'true';

    const animationToggles = document.querySelectorAll('.animation-toggle');
    function updateAnimationToggle() {
      animationToggles.forEach(btn => {
        btn.textContent = animationsEnabled ? 'Animações: Ligadas' : 'Animações: Desligadas';
        btn.classList.toggle('active', animationsEnabled);
        btn.setAttribute('aria-pressed', String(animationsEnabled));
      });
    }
    function setAnimations(enabled) {
      animationsEnabled = enabled;
      localStorage.setItem('otiAnimations', String(enabled));
      updateAnimationToggle();
      window.location.reload();
    }
    animationToggles.forEach(btn => {
      btn.addEventListener('click', () => setAnimations(!animationsEnabled));
    });
    updateAnimationToggle();

    document.body.classList.toggle('no-animations', !animationsEnabled);

    const isDesktop = window.matchMedia('(min-width: 1024px)').matches;
    const lenis = new Lenis({
      duration: animationsEnabled ? (isDesktop ? 1.05 : 0.95) : 0.45,
      easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: animationsEnabled,
      smoothTouch: false,   /* scroll nativo no touch — mais fluido */
      wheelMultiplier: animationsEnabled ? (isDesktop ? 0.85 : 1.05) : 1,
      touchMultiplier: 1.8, /* mais responsivo ao dedo */
    });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(time => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    /* ── UI: nav / progress / back-to-top ── */
    const navEl       = document.getElementById('navbar');
    const progressBar = document.getElementById('progress-bar');
    const backToTop   = document.getElementById('back-to-top');
    let lastScroll    = 0;
    lenis.on('scroll', ({ scroll, limit }) => {
      navEl.classList.toggle('scrolled', scroll > 60);
      progressBar.style.width = (scroll / limit * 100) + '%';
      backToTop.classList.toggle('visible', scroll > 500);
      if (scroll > 120) {
        navEl.classList.toggle('nav-hidden', scroll > lastScroll);
      } else {
        navEl.classList.remove('nav-hidden');
      }
      lastScroll = scroll;
    });
    backToTop.addEventListener('click', () => lenis.scrollTo(0, { duration: 1.6 }));

    /* ── MOBILE MENU ── */
    const hamburger  = document.querySelector('.hamburger');
    const navOverlay = document.getElementById('nav-overlay');
    if (hamburger) {
      hamburger.addEventListener('click', () => {
        const open = navOverlay.classList.toggle('open');
        hamburger.classList.toggle('active', open);
        if (open) { navEl.classList.remove('nav-hidden'); lenis.stop(); }
        else { lenis.start(); }
      });
    }
    document.querySelectorAll('a[href^="#"]:not(.overlay-link), .overlay-link').forEach(a => {
      a.addEventListener('click', function (e) {
        const t = document.querySelector(this.getAttribute('href'));
        if (!t) return;
        e.preventDefault();
        /* fecha overlay e reinicia Lenis ANTES de scrollar */
        navOverlay.classList.remove('open');
        if (hamburger) hamburger.classList.remove('active');
        lenis.start();
        /* pequeno delay garante que o Lenis já está rodando no mobile */
        setTimeout(() => lenis.scrollTo(t, { offset: -80, duration: 1.2 }), 30);
      });
    });

    /* ── UTILITÁRIO: anima quando entra na viewport ── */
    function reveal(el, from, to) {
      if (!el) return;
      gsap.set(el, from);
      new IntersectionObserver(([entry], obs) => {
        if (!entry.isIntersecting) return;
        gsap.to(el, to);
        obs.disconnect();
      }, { threshold: 0.05 }).observe(el);
    }
    function revealAll(selector, fromFn, toFn) {
      document.querySelectorAll(selector).forEach((el, i) => {
        reveal(el,
          typeof fromFn === 'function' ? fromFn(i) : fromFn,
          typeof toFn  === 'function' ? toFn(i)  : toFn
        );
      });
    }

    /* ── WORD SPLIT ── */
    function splitWords(el) {
      const words = [];
      function walk(node) {
        if (node.nodeType === 3) {
          const frag = document.createDocumentFragment();
          node.textContent.split(/(\s+)/).forEach(p => {
            if (!p.trim()) { frag.appendChild(document.createTextNode(p)); return; }
            const wrap = document.createElement('span'); wrap.className = 'word-wrap';
            const inner = document.createElement('span'); inner.className = 'word';
            inner.textContent = p; wrap.appendChild(inner); frag.appendChild(wrap);
            words.push(inner);
          });
          node.parentNode.replaceChild(frag, node);
        } else if (node.nodeName === 'EM') {
          const wrap = document.createElement('span'); wrap.className = 'word-wrap';
          const inner = document.createElement('span'); inner.className = 'word';
          inner.appendChild(node.cloneNode(true)); wrap.appendChild(inner);
          node.parentNode.replaceChild(wrap, node); words.push(inner);
        } else if (node.nodeName !== 'BR') {
          [...node.childNodes].forEach(walk);
        }
      }
      [...el.childNodes].forEach(walk);
      return words;
    }

    if (animationsEnabled) {
      const isMobileView = window.matchMedia('(max-width: 768px)').matches;

      /* ── HERO ENTRANCE (página carrega — sem ScrollTrigger) ── */
      gsap.timeline({ defaults: { ease: 'power4.out' }, delay: 0.1 })
        .from('.hero-tagline',     { opacity: 0, y: 30, duration: 0.9 })
        .from('.hero-name',        { opacity: 0, y: 80, duration: 1.1 }, '-=0.55')
        .from('.hero-subtitle',    { opacity: 0, y: 25, duration: 0.9 }, '-=0.6')
        .from('.hero-desc',        { opacity: 0, y: 20, duration: 0.85 }, '-=0.5')
        .from('.hero-cta',         { opacity: 0, y: 20, duration: 0.8 }, '-=0.45')
        .from('.hero-photo-frame', { opacity: 0, scale: 0.88, x: 50, duration: 1.4 }, 0.2)
        .from('.hero-badge',       { opacity: 0, scale: 0, duration: 0.65, ease: 'back.out(2)' }, '-=0.3')
        .from('.hero-scroll-hint', { opacity: 0, y: 10, duration: 0.7 }, '-=0.2');

      /* ── HERO PARALLAX (desktop only — desativado no mobile para fluidez) ── */
      gsap.matchMedia().add('(min-width: 769px)', () => {
        gsap.to('.hero-photo-frame', { yPercent: 25, ease: 'none',
          scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 1.5 } });
        gsap.to('.hero-content', { yPercent: 15, opacity: 0, ease: 'none',
          scrollTrigger: { trigger: '#hero', start: 'top top', end: '75% top', scrub: 1.5 } });
        gsap.to('.hero-bg-ornament', { yPercent: 10, ease: 'none',
          scrollTrigger: { trigger: '#hero', start: 'top top', end: 'bottom top', scrub: 2.5 } });
      });

      /* ── SECTION TITLES — word reveal ── */
      document.querySelectorAll('.section-title').forEach(title => {
        const words = splitWords(title);
        if (!words.length) return;
        gsap.set(words, { yPercent: 115, opacity: 0, rotationX: -15 });
        new IntersectionObserver(([entry], obs) => {
          if (!entry.isIntersecting) return;
          gsap.to(words, { yPercent: 0, opacity: 1, rotationX: 0,
            stagger: 0.04, duration: 0.9, ease: 'power4.out' });
          obs.disconnect();
        }, { threshold: 0.1 }).observe(title);
      });

      /* ── SECTION TAGS ── */
      revealAll('.section-tag',
        { opacity: 0, x: -40 },
        { opacity: 1, x: 0, duration: 0.85, ease: 'power3.out' });

      /* ── DIVIDERS ── */
      revealAll('.divider',
        { scaleX: 0, transformOrigin: 'left' },
        { scaleX: 1, duration: 0.95, ease: 'power3.inOut' });

      /* ── STAT CARDS + CONTADOR ── */
      document.querySelectorAll('.stat-card').forEach((card, i) => {
        gsap.set(card, { opacity: 0, y: 55, scale: 0.88 });
        new IntersectionObserver(([entry], obs) => {
          if (!entry.isIntersecting) return;
          gsap.to(card, { opacity: 1, y: 0, scale: 1, duration: 0.8,
            delay: i * 0.1, ease: 'power3.out' });
          const numEl  = card.querySelector('.stat-number');
          const raw    = numEl.textContent.replace(/\D/g, '');
          const suffix = numEl.textContent.replace(/\d/g, '');
          if (raw && +raw > 0) {
            const obj = { val: 0 };
            gsap.to(obj, { val: +raw, duration: 1.8, delay: i * 0.1, ease: 'power2.out',
              onUpdate() { numEl.textContent = Math.round(obj.val) + suffix; } });
          }
          obs.disconnect();
        }, { threshold: 0.1 }).observe(card);
      });

      /* ── TIMELINE — esquerda / direita ── */
      document.querySelectorAll('.timeline-item').forEach((item, i) => {
        const content = item.querySelector('.tl-content');
        const dot     = item.querySelector('.tl-dot-inner');
        if (!content) return;
        gsap.set(content, { opacity: 0, x: isMobileView ? 0 : (i % 2 === 0 ? -65 : 65), y: isMobileView ? 40 : 0 });
        if (dot) gsap.set(dot, { scale: 0 });
        new IntersectionObserver(([entry], obs) => {
          if (!entry.isIntersecting) return;
          gsap.to(content, { opacity: 1, x: 0, duration: 0.95, ease: 'power3.out' });
          if (dot) gsap.to(dot, { scale: 1, duration: 0.5, delay: 0.35, ease: 'back.out(2)' });
          obs.disconnect();
        }, { threshold: 0.1 }).observe(item);
      });

      /* ── SPEC CARDS ── */
      revealAll('.spec-card',
        { opacity: 0, y: 65 },
        i => ({ opacity: 1, y: 0, duration: 0.85, delay: (i % 2) * 0.15, ease: 'power3.out' }));

      /* ── INFO CARDS ── */
      revealAll('.info-card',
        isMobileView ? { opacity: 0, y: 40 } : { opacity: 0, x: 55 },
        i => ({ opacity: 1, x: 0, y: 0, duration: 0.8, delay: i * 0.1, ease: 'power3.out' }));

      /* ── PRESENÇA CARDS ── */
      revealAll('.presenca-card',
        { opacity: 0, y: 55, scale: 0.94 },
        i => ({ opacity: 1, y: 0, scale: 1, duration: 0.85, delay: (i % 2) * 0.15, ease: 'power3.out' }));

      /* ── VIDEO CARDS ── */
      revealAll('.video-card',
        { opacity: 0, y: 45, scale: 0.94 },
        i => ({ opacity: 1, y: 0, scale: 1, duration: 0.75, delay: (i % 3) * 0.1, ease: 'power3.out' }));

      /* ── TEXTO CORRIDO ── */
      revealAll('.sobre-text p, .sobre-quote, .professora-text p, .quote-box, .atuacao-list li',
        { opacity: 0, y: 25 },
        i => ({ opacity: 1, y: 0, duration: 0.8, delay: i * 0.06, ease: 'power3.out' }));

      /* ── GALLERY ITEMS ── */
      revealAll('.gallery-item',
        { opacity: 0, y: 30 },
        i => ({ opacity: 1, y: 0, duration: 0.7, delay: (i % 3) * 0.08, ease: 'power3.out' }));

      /* ── CLIPPING CARDS ── */
      revealAll('.clipping-card',
        { opacity: 0, y: 40, scale: 0.95 },
        i => ({ opacity: 1, y: 0, scale: 1, duration: 0.85,
                delay: (i % 3) * 0.1, ease: 'power3.out' }));

      /* ── THESMORPHORIA ── */
      (function () {
        const th   = document.querySelector('.thesmorphoria-highlight');
        const icon = document.querySelector('.thesm-icon');
        if (!th) return;
        gsap.set(th, { opacity: 0, x: isMobileView ? 0 : -55, y: isMobileView ? 40 : 0 });
        if (icon) gsap.set(icon, { opacity: 0, scale: 0 });
        new IntersectionObserver(([entry], obs) => {
          if (!entry.isIntersecting) return;
          gsap.to(th,   { opacity: 1, x: 0, duration: 1.05, ease: 'power3.out' });
          if (icon) gsap.to(icon, { opacity: 1, scale: 1, duration: 0.7, delay: 0.35, ease: 'back.out(2)' });
          obs.disconnect();
        }, { threshold: 0.05 }).observe(th);
      }());
    }

    /* ── LIGHTBOX (suporta galeria + clippings) ── */
    (function () {
      const clippingsData = [
        { src: 'Imagens%20Soraya%20Magalla/Jornal/WhatsApp%20Image%202026-05-15%20at%2015.39.33.jpeg', pub: 'Desafio · Arapiraca, AL · 1989', title: 'Sorhaya, a Deusa do Nilo' },
        { src: 'Imagens%20Soraya%20Magalla/Jornal/WhatsApp%20Image%202026-05-15%20at%2015.38.55.jpeg', pub: 'Gazeta de Alagoas · Caderno · Misticismo', title: 'Os movimentos da serpente' },
        { src: 'Imagens%20Soraya%20Magalla/Jornal/WhatsApp%20Image%202026-05-15%20at%2015.38.39.jpeg', pub: 'Gazeta Mulher · Maceió, AL · 09/11/1996', title: 'Soraya Magalla desvenda os mistérios da dança do ventre' },
        { src: 'Imagens%20Soraya%20Magalla/Jornal/WhatsApp%20Image%202026-05-15%20at%2015.39.13.jpeg', pub: 'Tribuna 2 · Maceió, AL · 06/06/1997', title: 'Mais do que sensualidade' },
        { src: 'Imagens%20Soraya%20Magalla/Jornal/WhatsApp%20Image%202026-05-15%20at%2015.38.27.jpeg', pub: 'Gazeta do Norte · Cianorte, PR', title: 'Dançarina alagoana ministra curso em Cianorte' }
      ];

      const galleryData = [
        { src: 'Imagens%20Soraya%20Magalla/WhatsApp%20Image%202026-05-15%20at%2015.32.21.jpeg',  pub: 'Performance',    title: 'Dança com espada — Egyptian Ballet' },
        { src: 'Imagens%20Soraya%20Magalla/WhatsApp%20Image%202026-05-15%20at%2015.37.09.jpeg',  pub: 'Figurino',       title: 'A Deusa do Nilo · Arapiraca, AL' },
        { src: 'Imagens%20Soraya%20Magalla/WhatsApp%20Image%202026-05-15%20at%2015.37.56.jpeg',  pub: 'Performance',    title: 'Dança da espada sob luz vermelha' },
        { src: 'Imagens%20Soraya%20Magalla/WhatsApp%20Image%202026-05-15%20at%2015.32.29.jpeg',  pub: 'Performance',    title: 'Dança do Véu' },
        { src: 'Imagens%20Soraya%20Magalla/WhatsApp%20Image%202026-05-15%20at%2015.37.19.jpeg',  pub: 'Figurino',       title: 'Egyptian Ballet · Figurino com correntes douradas' },
        { src: 'Imagens%20Soraya%20Magalla/Captura%20de%20tela%202026-05-14%20172309.png',       pub: 'Televisão',      title: 'Entrevista · Estúdio de TV' },
        { src: 'Imagens%20Soraya%20Magalla/WhatsApp%20Image%202026-05-15%20at%2015.32.36.jpeg',  pub: 'Performance',    title: 'Expressão com pandeiro — Flamenco' },
        { src: 'Imagens%20Soraya%20Magalla/Captura%20de%20tela%202026-05-15%20141819.png',       pub: 'Show',           title: 'Show ao ar livre · Nordeste' },
        { src: 'Imagens%20Soraya%20Magalla/ChatGPT%20Image%2015%20de%20mai.%20de%202026%2C%2016_08_14.png', pub: 'Ensino', title: 'Aula · Ballet Eliana Cavalcanti' },
        { src: 'Imagens%20Soraya%20Magalla/Captura%20de%20tela%202026-05-14%20172251.png',       pub: 'Internacional',  title: 'Roma, Itália' },
        { src: 'Imagens%20Soraya%20Magalla/Captura%20de%20tela%202026-05-14%20172417.png',       pub: 'Ensino',         title: 'Alunos · Ballet Eliana Cavalcanti' },
        { src: 'Imagens%20Soraya%20Magalla/Captura%20de%20tela%202026-05-15%20141953.png',       pub: 'Internacional',  title: 'Espanha · Centro de Arte Flamenco' }
      ];

      let activeGroup = clippingsData;
      let current = 0;
      const lb      = document.getElementById('lightbox');
      const lbImg   = document.getElementById('lb-img');
      const lbPub   = document.getElementById('lb-pub');
      const lbTitle = document.getElementById('lb-title');
      const lbCount = document.getElementById('lb-counter');

      function render() {
        const d = activeGroup[current];
        lbImg.style.opacity = '0';
        setTimeout(() => {
          lbImg.src = d.src; lbImg.alt = d.title;
          lbPub.textContent   = d.pub;
          lbTitle.textContent = d.title;
          lbCount.textContent = (current + 1) + ' / ' + activeGroup.length;
          lbImg.style.opacity = '1';
        }, 150);
      }

      function openLb(group, i) {
        activeGroup = group; current = i;
        render(); lb.classList.add('open'); lenis.stop();
      }

      function closeLb() { lb.classList.remove('open'); lenis.start(); }

      function go(dir) {
        current = (current + dir + activeGroup.length) % activeGroup.length;
        render();
      }

      function wire(selector, group) {
        document.querySelectorAll(selector).forEach((el, i) => {
          el.setAttribute('role', 'button'); el.setAttribute('tabindex', '0');
          el.addEventListener('click', () => openLb(group, i));
          el.addEventListener('keydown', e => {
            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openLb(group, i); }
          });
        });
      }

      wire('.clipping-card', clippingsData);
      wire('.gallery-item',  galleryData);

      document.getElementById('lb-close').addEventListener('click', closeLb);
      document.getElementById('lb-prev').addEventListener('click', () => go(-1));
      document.getElementById('lb-next').addEventListener('click', () => go(1));
      lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
      document.addEventListener('keydown', e => {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape')     closeLb();
        if (e.key === 'ArrowLeft')  go(-1);
        if (e.key === 'ArrowRight') go(1);
      });
    }());

    /* ── LGPD COOKIE BANNER ── */
    (function () {
      const banner  = document.getElementById('cookie-banner');
      const accept  = document.getElementById('cookie-accept');
      const decline = document.getElementById('cookie-decline');
      if (!localStorage.getItem('otiCookies')) {
        setTimeout(() => banner.classList.add('visible'), 3800);
      }
      const dismiss = (choice) => {
        localStorage.setItem('otiCookies', choice);
        banner.classList.remove('visible');
      };
      accept.addEventListener('click',  () => dismiss('accepted'));
      decline.addEventListener('click', () => dismiss('declined'));
    }());

    /* ── SHARE BUTTON ── */
    (function () {
      const shareBtn = document.getElementById('share-btn');
      lenis.on('scroll', ({ scroll }) => {
        shareBtn.classList.toggle('visible', scroll > 600);
      });
      shareBtn.addEventListener('click', async () => {
        const data = {
          title: 'Soraya Magalla — Bailarina · Coreógrafa · Professora',
          text:  'Pioneira da dança árabe no Nordeste do Brasil.',
          url:   window.location.href
        };
        if (navigator.share) {
          try { await navigator.share(data); } catch (_) {}
        } else {
          await navigator.clipboard.writeText(data.url);
          const orig = shareBtn.style.getPropertyValue('--tip') || '';
          shareBtn.setAttribute('data-tip', 'Link copiado!');
          shareBtn.style.setProperty('--tip', 'Link copiado!');
          setTimeout(() => shareBtn.setAttribute('data-tip', ''), 2000);
        }
      });
    }());

    /* ── INTERNACIONALIZAÇÃO (PT / EN / ES) ── */
    const translations = {

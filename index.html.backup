        'spec.2.desc':'Arte milenario con raíces en el antiguo Egipto, la danza del vientre es el corazón del trabajo de Soraya. Explora sus aspectos terapéuticos, espirituales y femeninos, además de la técnica tradicional.',
        'spec.3.desc':'La pasión española encuentra el alma árabe. El flamenco forma parte de la paleta artística de Soraya como extensión natural de su búsqueda por la expresión corporal más intensa y dramática.',
        'spec.4.desc':'La conexión entre el movimiento y la espiritualidad femenina. Soraya incorpora en su trabajo una visión de la danza como ritual, sanación y autoconocimiento — transformando el escenario en espacio sagrado.',
        'prof.title':'Formando nuevas<br><em>generaciones</em>',
        'prof.p1':'<strong>Soraya Magalla</strong> dedicó gran parte de su carrera a la enseñanza. Se hizo conocida por la formación de nuevas bailarinas y por la valorización de la cultura árabe en el Nordeste.',
        'prof.p2':'Impartió <em>cursos, talleres y actuaciones</em> en diferentes ciudades brasileñas, llevando el arte oriental a donde fuera — de Alagoas hasta el interior de Paraná.',
        'prof.quote':'"La danza ha sido utilizada como forma de terapia capaz de superar y fortalecer la autoestima de la mujer, contribuyendo al equilibrio físico y emocional."',
        'prof.li1':'Cursos y talleres en múltiples ciudades brasileñas','prof.li2':'Formación de bailarinas que actúan en todo el Nordeste',
        'prof.li3':'Valorización de la cultura árabe y oriental en la región','prof.li4':'Actuaciones con enfoque terapéutico y espiritual','prof.li5':'Proyectos vinculados al sagrado femenino y la cultura oriental',
        'imp.title':'En los <em>medios</em> brasileños','imp.intro':'De Alagoas a Paraná — cinco décadas de cobertura periodística que documentan la trayectoria de Soraya Magalla en la prensa brasileña.',
        'pres.title':'Arte más allá<br>de los <em>escenarios</em>','pres.intro':'La presencia de Soraya Magalla va mucho más allá de las actuaciones en vivo. Su arte llega a personas en múltiples plataformas y contextos culturales en todo Brasil.',
        'gal.title':'Momentos en <em>movimiento</em>','gal.intro':'Tres décadas de arte capturadas en imágenes — desde los escenarios de Alagoas hasta las escenas internacionales.',
        'ent.title':'Voz y <em>movimiento</em>','ent.intro':'Soraya Magalla concedió entrevistas y participó en producciones audiovisuales que documentan su trayectoria, su arte y sus contribuciones a la cultura oriental en Brasil.',
      }
    };

    function setLanguage(lang) {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const t = translations[lang]?.[el.dataset.i18n];
        if (t !== undefined) el.innerHTML = t;
      });
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.lang === lang);
      });
      document.documentElement.lang = lang === 'pt' ? 'pt-BR' : lang;
      localStorage.setItem('otiLang', lang);
    }

    const savedLang = localStorage.getItem('otiLang') ||
      (navigator.language?.startsWith('es') ? 'es' : navigator.language?.startsWith('en') ? 'en' : 'pt');
    setLanguage(savedLang);

    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => setLanguage(btn.dataset.lang));
    });
  </script>
</body>
</html>

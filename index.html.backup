  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cream: #0e0b06;
      --cream-dark: #1a1509;
      --gold: #c9a85c;
      --gold-light: #d9b96c;
      --gold-dark: #a67c3a;
      --ink: #f5ead0;
      --ink-soft: #d4c5a0;
      --ink-muted: #9a8b6e;
      --white: #ffffff;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Raleway', sans-serif;
      background-color: var(--cream);
      color: var(--ink);
      overflow-x: clip;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--cream-dark); }
    ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      padding: 1.5rem 4rem;
      display: flex; justify-content: space-between; align-items: center;
      background: #0e0b06;
      border-bottom: 1px solid rgba(201,168,92,0.15);
      transition: padding 0.4s, border-color 0.4s, transform 0.35s ease;
    }
    nav.nav-hidden { transform: translateY(-110%); }
    nav.scrolled {
      background: rgba(14,11,6,0.97);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      padding: 1rem 4rem;
      border-bottom: 1px solid rgba(201,168,92,0.3);
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem; font-weight: 600; letter-spacing: 0.08em;
      color: var(--ink); text-decoration: none;
    }
    .nav-logo span { color: var(--gold); }
    .nav-links { display: none; gap: 2.5rem; list-style: none; margin-left: auto; }
    .animation-toggle {
      display: none;
    }
    @media (min-width: 1025px) and (hover: hover) and (pointer: fine) {
      .animation-toggle {
        display: inline-flex;
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 999px;
        background: transparent;
        color: var(--ink-soft);
        padding: 0.55rem 1rem;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.25s, color 0.25s, border-color 0.25s;
        white-space: nowrap;
        margin-left: 1.5rem;
      }
    }
    .animation-toggle:hover,
    .animation-toggle.active {
      background: rgba(201,168,92,0.12);
      color: var(--gold);
      border-color: rgba(201,168,92,0.45);
    }
    .lang-switcher {
      display: none;
      align-items: center;
      gap: 0.25rem;
      margin-left: 1.2rem;
    }
    @media (min-width: 1025px) and (hover: hover) and (pointer: fine) {
      .lang-switcher { display: flex; }
    }
    .lang-btn {
      background: none; border: none; cursor: pointer;
      font-family: 'Raleway', sans-serif;
      font-size: 0.68rem; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--ink-muted);
      padding: 0.2rem 0.3rem; transition: color 0.25s;
    }
    .lang-btn:hover { color: var(--gold); }
    .lang-btn.active { color: var(--gold); border-bottom: 1px solid var(--gold); }
    .lang-sep { color: rgba(201,168,92,0.25); font-size: 0.6rem; user-select: none; }
    /* lang no overlay mobile */
    .overlay-lang {
      display: flex; align-items: center; gap: 0.4rem; margin-top: 0.5rem;
    }
    .overlay-lang .lang-btn {
      font-size: 0.75rem; padding: 0.3rem 0.5rem;
      border: 1px solid rgba(201,168,92,0.2); border-radius: 4px;
    }
    .overlay-lang .lang-btn.active {
      border-color: var(--gold); color: var(--gold);
    }
    .nav-links a {
      font-size: 0.78rem; font-weight: 500; letter-spacing: 0.15em;
      text-transform: uppercase; text-decoration: none;
      color: var(--ink-soft); transition: color 0.3s; position: relative;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: -3px; left: 0;
      width: 0; height: 1px; background: var(--gold); transition: width 0.3s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-links a:hover::after { width: 100%; }

    /* HERO */
    #hero {
      min-height: 100vh;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center; padding: 6rem 4rem 0;
      position: relative; overflow: hidden;
    }
    .hero-bg-ornament {
      position: absolute; top: -10%; right: -5%;
      width: 55vw; height: 110vh;
      background: var(--cream-dark);
      clip-path: polygon(15% 0%, 100% 0%, 100% 100%, 0% 100%);
      z-index: 0;
    }
    .hero-content { position: relative; z-index: 2; padding-right: 3rem; }
    .hero-tagline {
      display: inline-flex; align-items: center; gap: 0.8rem;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem;
    }
    .hero-tagline::before { content: ''; display: block; width: 30px; height: 1px; background: var(--gold); }
    .hero-name {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3.5rem, 6vw, 6rem); font-weight: 700;
      line-height: 1.0; color: var(--ink); margin-bottom: 0.3rem;
    }
    .hero-name .accent { color: var(--gold); font-style: italic; }
    .hero-subtitle {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1rem, 2vw, 1.4rem); font-weight: 400;
      font-style: italic; color: var(--ink-muted);
      margin-bottom: 2.5rem; letter-spacing: 0.03em;
    }
    .hero-desc {
      font-size: 0.95rem; font-weight: 300; line-height: 1.85;
      color: var(--ink-soft); max-width: 420px; margin-bottom: 3rem;
    }
    .hero-cta {
      display: inline-flex; align-items: center; gap: 0.8rem;
      padding: 0.9rem 2.2rem; background: var(--gold-dark);
      color: var(--white); font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase;
      text-decoration: none; transition: background 0.3s, gap 0.3s;
    }
    .hero-cta:hover { background: var(--gold); gap: 1.2rem; }
    .hero-visual { position: relative; z-index: 2; display: flex; justify-content: center; align-items: center; }
    .hero-photo-frame { position: relative; width: min(380px, 45vw); aspect-ratio: 3/4; }
    .hero-photo-frame .frame-border {
      position: absolute; inset: -16px;
      border: 1.5px solid var(--gold); z-index: 0; opacity: 0.5;
    }
    .hero-photo-frame .frame-border-2 {
      position: absolute; inset: -8px;
      border: 1px solid var(--gold); z-index: 0; opacity: 0.25;
    }
    .hero-photo { width: 100%; height: 100%; position: relative; z-index: 1; overflow: hidden; background: var(--cream-dark); }
    .hero-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
    .hero-badge {
      position: absolute; bottom: -1.5rem; right: -1.5rem;
      width: 100px; height: 100px; background: var(--gold); border-radius: 50%;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center; z-index: 3; box-shadow: 0 8px 32px rgba(201,168,92,0.4);
    }
    .hero-badge .year { font-size: 1.4rem; font-weight: 700; color: var(--white); line-height: 1; }
    .hero-badge .badge-text { font-size: 0.52rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.85); margin-top: 2px; }
    .hero-scroll-hint {
      position: absolute; bottom: 2.5rem; left: 4rem;
      display: flex; align-items: center; gap: 0.6rem;
      font-size: 0.7rem; font-weight: 500; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--ink-muted); z-index: 2;
    }
    .scroll-line { width: 40px; height: 1px; background: var(--ink-muted); position: relative; overflow: hidden; }
    .scroll-line::after {
      content: ''; position: absolute; top: 0; left: -100%;
      width: 100%; height: 100%; background: var(--gold);
      animation: scrollLine 2s ease-in-out infinite;
    }
    @keyframes scrollLine { 0% { left: -100%; } 50%, 100% { left: 100%; } }

    /* SECTION COMMONS */
    section { padding: 8rem 4rem; }
    .section-tag {
      display: inline-flex; align-items: center; gap: 0.8rem;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem;
    }
    .section-tag::before { content: ''; display: block; width: 24px; height: 1px; background: var(--gold); }
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 700;
      color: var(--ink); line-height: 1.15; margin-bottom: 1rem;
    }
    .section-title em { font-style: italic; color: var(--gold); }
    .divider { width: 50px; height: 2px; background: var(--gold); margin: 1.5rem 0 2.5rem; }

    /* PERFIL (SOBRE) */
    #sobre {
      background: var(--cream-dark);
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 6rem; align-items: center;
    }
    .sobre-text p { font-size: 0.97rem; font-weight: 300; line-height: 1.9; color: var(--ink-soft); margin-bottom: 1.4rem; }
    .sobre-text p strong { font-weight: 600; color: var(--ink); }
    .sobre-text p em { font-style: italic; color: var(--gold-light); }
    .sobre-quote {
      margin: 2.5rem 0; padding: 2rem 2rem 2rem 2.5rem;
      border-left: 3px solid var(--gold); background: var(--cream);
    }
    .sobre-quote p {
      font-family: 'Playfair Display', serif; font-size: 1.15rem;
      font-style: italic; font-weight: 400; color: var(--ink-soft);
      line-height: 1.6; margin: 0;
    }
    .sobre-quote cite {
      display: block; margin-top: 0.8rem; font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold); font-style: normal;
    }
    .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .stat-card {
      padding: 1.8rem; background: var(--cream);
      border: 1px solid rgba(201,168,92,0.15); text-align: center;
      transition: border-color 0.3s, transform 0.3s;
    }
    .stat-card:hover { border-color: var(--gold); transform: translateY(-4px); }
    .stat-number { font-family: 'Playfair Display', serif; font-size: 2.6rem; font-weight: 700; color: var(--gold); line-height: 1; }
    .stat-label { font-size: 0.73rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-muted); margin-top: 0.5rem; line-height: 1.4; }

    /* FORMAÇÃO (TIMELINE) */
    #formacao { background: var(--cream); position: relative; }
    .timeline-header { max-width: 520px; margin-bottom: 5rem; }
    .timeline { position: relative; max-width: 800px; margin: 0 auto; }
    .timeline::before {
      content: ''; position: absolute; top: 0; bottom: 0; left: 50%;
      transform: translateX(-50%); width: 1px;
      background: linear-gradient(to bottom, transparent, var(--gold) 10%, var(--gold) 90%, transparent);
    }
    .timeline-item {
      display: grid; grid-template-columns: 1fr 60px 1fr;
      align-items: start; margin-bottom: 3.5rem;
    }
    .timeline-item:nth-child(odd) .tl-content { grid-column: 1; text-align: right; padding-right: 2rem; }
    .timeline-item:nth-child(odd) .tl-empty { grid-column: 3; }
    .timeline-item:nth-child(even) .tl-content { grid-column: 3; text-align: left; padding-left: 2rem; }
    .timeline-item:nth-child(even) .tl-empty { grid-column: 1; }
    .tl-dot { grid-column: 2; display: flex; justify-content: center; align-items: flex-start; padding-top: 0.3rem; }
    .tl-dot-inner {
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--cream); border: 2.5px solid var(--gold);
      position: relative; flex-shrink: 0;
    }
    .tl-dot-inner::before { content: ''; position: absolute; inset: 3px; border-radius: 50%; background: var(--gold); }
    .tl-year { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 0.5rem; }
    .tl-title { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.4rem; }
    .tl-desc { font-size: 0.85rem; font-weight: 300; line-height: 1.7; color: var(--ink-muted); }

    /* ESPECIALIZAÇÃO */
    #especializacao { background: var(--cream-dark); }
    .especializacao-header { max-width: 600px; margin-bottom: 4rem; }
    .especializacao-intro { font-size: 0.97rem; font-weight: 300; line-height: 1.85; color: var(--ink-soft); }
    .especializacao-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .spec-card {
      padding: 2.5rem 2rem; background: var(--cream);
      border: 1px solid rgba(201,168,92,0.15);
      position: relative; overflow: hidden;
      transition: border-color 0.3s, transform 0.3s;
    }
    .spec-card::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 3px; height: 0; background: var(--gold);
      transition: height 0.4s ease;
    }
    .spec-card:hover::before { height: 100%; }
    .spec-card:hover { border-color: rgba(201,168,92,0.4); transform: translateX(4px); }
    .spec-number {
      font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 700;
      color: rgba(201,168,92,0.12); line-height: 1;
      position: absolute; top: 1rem; right: 1.5rem;
    }
    .spec-icon {
      width: 48px; height: 48px; border: 1px solid rgba(201,168,92,0.3);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.5rem; color: var(--gold);
    }
    .spec-title { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 600; color: var(--ink); margin-bottom: 0.8rem; }
    .spec-desc { font-size: 0.87rem; font-weight: 300; line-height: 1.8; color: var(--ink-muted); }

    /* PROFESSORA */
    #professora {
      background: var(--cream);
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 6rem; align-items: center;
    }
    .professora-text p { font-size: 0.97rem; font-weight: 300; line-height: 1.9; color: var(--ink-soft); margin-bottom: 1.4rem; }
    .professora-text p strong { font-weight: 600; color: var(--ink); }
    .professora-text p em { font-style: italic; color: var(--gold-light); }
    .quote-box {
      padding: 2rem 2rem 2rem 2.5rem;
      border-left: 3px solid var(--gold);
      background: var(--cream-dark); margin: 2rem 0;
    }
    .quote-box p { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-style: italic; color: var(--ink-soft); line-height: 1.7; margin: 0; }
    .atuacao-list { list-style: none; margin-top: 1.5rem; }
    .atuacao-list li {
      display: flex; align-items: flex-start; gap: 1rem;
      font-size: 0.9rem; font-weight: 300; color: var(--ink-soft);
      margin-bottom: 0.8rem; line-height: 1.6;
    }
    .atuacao-list li::before { content: '→'; color: var(--gold); font-size: 0.8rem; margin-top: 0.15rem; flex-shrink: 0; }
    .info-cards { display: grid; grid-template-columns: 1fr; gap: 1rem; }
    .info-card {
      padding: 1.5rem 2rem; background: var(--cream-dark);
      border: 1px solid rgba(201,168,92,0.15);
      display: flex; align-items: center; gap: 1.5rem;
      transition: border-color 0.3s, transform 0.3s;
    }
    .info-card:hover { border-color: var(--gold); transform: translateX(6px); }
    .info-card-icon {
      width: 44px; height: 44px;
      background: rgba(201,168,92,0.1); border: 1px solid rgba(201,168,92,0.25);
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); flex-shrink: 0;
    }
    .info-card-text .label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.3rem; }
    .info-card-text .value { font-size: 0.88rem; font-weight: 400; color: var(--ink-soft); line-height: 1.4; }

    /* IMPRENSA — fundo jornalístico vintage */
    #imprensa {
      position: relative;
      padding: 8rem 4rem;
      overflow: hidden;
      /* fundo base: preto quente com tom sépia */
      background-color: #0d0a06;
      /* camadas: grão + pontos halftone + divisórias de coluna */
      background-image:
        url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='256' height='256'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.78' numOctaves='4' stitchTiles='stitch'/><feColorMatrix type='saturate' values='0'/></filter><rect width='256' height='256' filter='url(%23n)' opacity='0.11'/></svg>"),
        radial-gradient(circle, rgba(210,180,115,0.055) 1px, transparent 1px),
        repeating-linear-gradient(90deg,
          transparent 0, transparent calc(33.33% - 0.5px),
          rgba(210,180,110,0.07) calc(33.33% - 0.5px), rgba(210,180,110,0.07) calc(33.33% + 0.5px),
          transparent calc(33.33% + 0.5px), transparent calc(66.66% - 0.5px),
          rgba(210,180,110,0.07) calc(66.66% - 0.5px), rgba(210,180,110,0.07) calc(66.66% + 0.5px),
          transparent calc(66.66% + 0.5px)
        );
      background-size: 256px 256px, 7px 7px, 100% 100%;
    }
    /* vinheta âmbar: bordas escuras + luz central quente embaixo */
    #imprensa::before {
      content: '';
      position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse 75% 55% at 50% 108%, rgba(180,138,55,0.11) 0%, transparent 100%),
        linear-gradient(180deg, rgba(5,3,1,0.55) 0%, transparent 22%, transparent 72%, rgba(5,3,1,0.45) 100%),
        linear-gradient(90deg, rgba(5,3,1,0.35) 0%, transparent 18%, transparent 82%, rgba(5,3,1,0.35) 100%);
    }
    /* watermark: ano grande e esmaecido ao fundo */
    #imprensa::after {
      content: '1997';
      position: absolute; bottom: 1rem; right: 3%; z-index: 0;
      font-family: 'Playfair Display', serif;
      font-size: clamp(9rem, 26vw, 20rem);
      font-weight: 700; line-height: 1;
      color: rgba(210,180,100,0.04);
      pointer-events: none; user-select: none;
      letter-spacing: -0.02em;
    }
    /* garante que o conteúdo fica acima das camadas */
    #imprensa > * { position: relative; z-index: 1; }
    .imprensa-header { max-width: 520px; margin-bottom: 3rem; }
    .newspaper-outer {
      max-width: 860px; margin: 0 auto;
      background: #f2ead9; padding: 3rem 3.5rem;
      box-shadow: 0 24px 80px rgba(0,0,0,0.55), 4px 4px 0 #c9b99a;
      border: 1px solid #c9b99a; position: relative;
    }
    .newspaper-outer::before {
      content: ''; position: absolute; inset: 10px;
      border: 1px solid rgba(180,155,110,0.4); pointer-events: none;
    }
    .np-rule-thick { border: none; border-top: 4px solid #1a1410; margin: 0; }
    .np-rule-double { border: none; border-top: 3px double #1a1410; margin: 0.4rem 0 0; }
    .np-masthead { text-align: center; }
    .np-name { font-family: 'Playfair Display', serif; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 700; color: #1a1410; letter-spacing: 0.14em; text-transform: uppercase; line-height: 1; padding: 0.5rem 0 0.3rem; }
    .np-sub { font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase; color: #5a4a3a; font-family: 'Raleway', sans-serif; padding-bottom: 0.5rem; }
    .np-dateline {
      display: flex; justify-content: space-between;
      font-family: 'Raleway', sans-serif; font-size: 0.65rem;
      letter-spacing: 0.1em; text-transform: uppercase; color: #5a4a3a;
      border-top: 1px solid #1a1410; border-bottom: 1px solid #1a1410;
      padding: 0.35rem 0; margin: 0.5rem 0 2rem;
    }
    .np-section-tag { display: inline-block; font-family: 'Raleway', sans-serif; font-size: 0.62rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; background: #1a1410; color: #f2ead9; padding: 0.2rem 0.7rem; margin-bottom: 0.9rem; }
    .np-spread { display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; }
    .np-headline { font-family: 'Playfair Display', serif; font-size: clamp(1.5rem, 2.8vw, 2.1rem); font-weight: 700; line-height: 1.15; color: #1a1410; margin-bottom: 1rem; border-bottom: 2px solid #1a1410; padding-bottom: 0.8rem; }
    .np-byline { font-family: 'Raleway', sans-serif; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: #5a4a3a; margin-bottom: 1.2rem; text-decoration: underline; }
    .np-body { font-family: 'Playfair Display', serif; font-size: 0.9rem; line-height: 1.9; color: #2a2218; text-align: justify; }
    .np-body p { margin-bottom: 0.9rem; }
    .np-body p:first-child::first-letter { font-size: 4rem; font-weight: 700; float: left; line-height: 0.72; margin-right: 0.07em; margin-top: 0.08em; color: #1a1410; }
    .np-figure { margin: 0; }
    .np-figure img { width: 100%; height: auto; display: block; border: 1px solid #aaa; }
    .np-caption { font-family: 'Playfair Display', serif; font-size: 0.7rem; font-style: italic; color: #5a4a3a; text-align: center; margin-top: 0.6rem; line-height: 1.5; border-bottom: 1px solid #c9b99a; padding-bottom: 0.6rem; }
    .np-footer-rule { border: none; border-top: 1px solid #1a1410; margin: 2rem 0 0; }
    .np-footer-text { font-family: 'Raleway', sans-serif; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: #7a6a5a; text-align: center; margin-top: 0.5rem; }

    /* PRESENÇA CULTURAL */
    #presenca { background: var(--cream); }
    .presenca-header { max-width: 600px; margin-bottom: 4rem; }
    .presenca-intro { font-size: 0.97rem; font-weight: 300; line-height: 1.85; color: var(--ink-soft); }
    .presenca-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .presenca-card {
      padding: 2rem; background: var(--cream-dark);
      border: 1px solid rgba(201,168,92,0.12);
      display: flex; flex-direction: column; gap: 1.2rem;
      transition: border-color 0.3s, transform 0.3s;
    }
    .presenca-card:hover { border-color: rgba(201,168,92,0.4); transform: translateY(-4px); }
    .presenca-card-header { display: flex; align-items: center; gap: 1rem; }
    .presenca-icon {
      width: 42px; height: 42px;
      background: rgba(201,168,92,0.1); border: 1px solid rgba(201,168,92,0.25);
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); flex-shrink: 0;
    }
    .presenca-platform { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); }
    .presenca-card-title { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 600; color: var(--ink); }
    .presenca-card-desc { font-size: 0.85rem; font-weight: 300; line-height: 1.75; color: var(--ink-muted); }
    .presenca-link {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-size: 0.75rem; font-weight: 500; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--gold); text-decoration: none;
      margin-top: auto; transition: gap 0.3s;
    }
    .presenca-link:hover { gap: 0.8rem; }

    /* FOOTER */
    footer {
      background: var(--cream-dark); padding: 4rem;
      border-top: 1px solid rgba(201,168,92,0.15);
      position: relative;
    }
    footer::before {
      content: '';
      position: absolute;
      top: -1px; left: 20%; right: 20%; height: 1px;
      background: linear-gradient(90deg,
        transparent, rgba(201,168,92,0.4) 20%,
        rgba(201,168,92,0.7) 50%,
        rgba(201,168,92,0.4) 80%, transparent
      );
    }
    footer::after {
      content: '';
      position: absolute;
      top: -5px; left: 50%;
      transform: translateX(-50%) rotate(45deg);
      width: 8px; height: 8px;
      background: var(--gold);
      box-shadow: 0 0 10px rgba(201,168,92,0.6);
    }
    .footer-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem; align-items: start; }
    .footer-brand .brand-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; color: var(--ink); margin-bottom: 0.4rem; }
    .footer-brand .brand-name span { color: var(--gold); font-style: italic; }
    .footer-brand .brand-desc { font-size: 0.82rem; font-weight: 300; line-height: 1.7; color: rgba(240,228,232,0.45); max-width: 300px; margin-top: 0.8rem; }
    .ornament-line { width: 40px; height: 1px; background: var(--gold); margin: 1.2rem 0; }
    .social-links { display: flex; gap: 1rem; margin-top: 1.2rem; }
    .social-link { width: 38px; height: 38px; border: 1px solid rgba(201,168,92,0.3); display: flex; align-items: center; justify-content: center; color: rgba(240,228,232,0.5); text-decoration: none; transition: border-color 0.3s, color 0.3s, background 0.3s; }
    .social-link:hover { border-color: var(--gold); color: var(--gold); background: rgba(201,168,92,0.08); }
    .footer-col h4 { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem; }
    .footer-col ul { list-style: none; }
    .footer-col ul li { font-size: 0.85rem; font-weight: 300; color: rgba(240,228,232,0.5); margin-bottom: 0.6rem; }
    .footer-col ul li a { color: inherit; text-decoration: none; transition: color 0.3s; }
    .footer-col ul li a:hover { color: var(--gold); }
    .footer-bottom { max-width: 1200px; margin: 3rem auto 0; padding-top: 2rem; border-top: 1px solid rgba(201,168,92,0.1); display: flex; justify-content: space-between; align-items: center; }
    .footer-copy { font-size: 0.75rem; color: rgba(240,228,232,0.25); font-weight: 300; letter-spacing: 0.05em; }
    .footer-copy span { color: var(--gold); }

    /* animações gerenciadas 100% pelo GSAP */

    /* ── MOBILE PERFORMANCE ── */
    /* GPU layers nos elementos que mais animam */
    .hero-photo-frame, .hero-content, .hero-bg-ornament {
      will-change: transform;
    }
    /* overscroll nativo contido — evita o "rubber band" no iOS */
    html {
      overflow-x: clip;
      touch-action: pan-y;
    }
    body {
      overscroll-behavior-x: contain;
      overscroll-behavior-y: contain;
      touch-action: pan-y;
    }

    @media (max-width: 768px) {
      nav {
        gap: 0.75rem;
      }
      .hamburger {
        order: 3;
      }
      .nav-logo {
        order: 1;
      }
      /* remove filtros pesados de imagem no mobile */
      .gallery-item img { filter: brightness(0.92); }
      .clipping-card img { filter: sepia(0.4); }
      /* transições mais rápidas no mobile */
      .gallery-item img,
      .clipping-card img,
      .gallery-item-overlay,
      .clipping-overlay { transition-duration: 0.25s; }
      /* sem backdrop-filter no mobile (caro em GPU) */
      nav.scrolled { backdrop-filter: none; -webkit-backdrop-filter: none; }
      .lb-caption { backdrop-filter: none; -webkit-backdrop-filter: none; }
    }

    /* ENTREVISTAS */
    #entrevistas { background: var(--cream-dark); }
    .entrevistas-header { max-width: 600px; margin-bottom: 3rem; }
    .entrevistas-intro { font-size: 0.97rem; font-weight: 300; line-height: 1.85; color: var(--ink-soft); }

    .thesmorphoria-highlight {
      background: var(--cream);
      border: 1px solid rgba(201,168,92,0.2);
      border-left: 3px solid var(--gold);
      padding: 2.5rem;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 2rem;
      align-items: start;
      margin-bottom: 3.5rem;
    }
    .thesm-icon {
      width: 64px; height: 64px;
      background: rgba(201,168,92,0.1); border: 1px solid rgba(201,168,92,0.3);
      display: flex; align-items: center; justify-content: center;
      color: var(--gold); flex-shrink: 0;
    }
    .thesm-label { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.6rem; }
    .thesm-title { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: var(--ink); margin-bottom: 1rem; line-height: 1.3; }
    .thesm-desc { font-size: 0.9rem; font-weight: 300; line-height: 1.9; color: var(--ink-soft); }
    .thesm-desc em { font-style: italic; color: var(--gold-light); }
    .thesm-desc strong { font-weight: 600; color: var(--ink); }
    .thesm-desc br { display: block; margin-top: 0.9rem; }

    .videos-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
    .video-card {
      background: var(--cream); border: 1px solid rgba(201,168,92,0.12);
      overflow: hidden; transition: border-color 0.3s, transform 0.3s;
      text-decoration: none; display: block;
    }
    .video-card:hover { border-color: rgba(201,168,92,0.4); transform: translateY(-4px); }
    .video-thumb-wrapper {
      position: relative; width: 100%; aspect-ratio: 16/9; overflow: hidden; background: #000;
    }
    .video-thumb-wrapper img {
      width: 100%; height: 100%; object-fit: cover; display: block;
      transition: transform 0.4s ease, opacity 0.3s;
    }
    .video-card:hover .video-thumb-wrapper img { transform: scale(1.04); opacity: 0.75; }
    .video-play-btn {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      pointer-events: none;
    }
    .video-play-btn span {
      width: 52px; height: 52px; border-radius: 50%;
      background: rgba(201,168,92,0.85);
      display: flex; align-items: center; justify-content: center;
      transition: background 0.3s, transform 0.3s;
      box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    }
    .video-card:hover .video-play-btn span { background: var(--gold); transform: scale(1.1); }
    .video-play-btn svg { margin-left: 3px; }
    .video-label {
      padding: 0.75rem 1rem;
      font-size: 0.7rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--ink-muted); border-top: 1px solid rgba(201,168,92,0.08);
    }
    .video-card.featured .video-label { color: var(--gold); }

    /* WORD SPLIT */
    .word-wrap { display: inline-block; overflow: hidden; vertical-align: bottom; }
    .word-wrap .word { display: inline-block; }
    .section-title { perspective: 900px; }

    /* PROGRESS BAR */
    #progress-bar {
      position: fixed; top: 0; left: 0; z-index: 200;
      height: 2px; width: 0%;
      background: linear-gradient(90deg, var(--gold-dark), var(--gold), var(--gold-light));
      transition: width 0.1s linear;
      pointer-events: none;
    }

    /* BACK TO TOP */
    #back-to-top {
      position: fixed; bottom: 2rem; right: 2rem; z-index: 150;
      width: 44px; height: 44px;
      background: var(--gold-dark); border: 1px solid rgba(201,168,92,0.4);
      display: flex; align-items: center; justify-content: center;
      color: var(--white); cursor: pointer;
      opacity: 0; transform: translateY(12px);
      transition: opacity 0.3s, transform 0.3s, background 0.3s;
      pointer-events: none;
    }
    #back-to-top.visible { opacity: 1; transform: translateY(0); pointer-events: auto; }
    #back-to-top:hover { background: var(--gold); }

    /* MOBILE NAV OVERLAY */
    .nav-overlay {
      position: fixed; inset: 0; z-index: 90;
      background: rgba(14,11,6,0.97);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 1.8rem;
      padding: 5rem 1rem 2rem;
      overflow-y: auto;
      opacity: 0; pointer-events: none;
      transition: opacity 0.35s ease;
    }
    .nav-overlay.open { opacity: 1; pointer-events: auto; }
    .nav-overlay a {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.3rem, 5vw, 2rem); font-weight: 700;
      color: var(--ink-soft); text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.3s;
      touch-action: manipulation;
      -webkit-tap-highlight-color: transparent;
    }
    .nav-overlay a:hover { color: var(--gold); }
    .hamburger.active span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .hamburger.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .hamburger.active span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

    /* HAMBURGER */
    .hamburger { display: flex; flex-direction: column; gap: 5px; cursor: pointer; background: none; border: none; padding: 4px; z-index: 101; position: relative; touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
    .hamburger span { display: block; width: 24px; height: 1.5px; background: var(--ink); transition: transform 0.3s, opacity 0.3s; }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
      nav { padding: 1.2rem 1.5rem; max-width: 100vw; overflow: hidden; box-sizing: border-box; }
      nav.scrolled { padding: 0.8rem 1.5rem; }
      .nav-links { display: none; }
      .hamburger { display: flex; }
      #hero { grid-template-columns: 1fr; padding: 7rem 2rem 4rem; text-align: center; }
      .hero-bg-ornament { display: none; }
      .hero-content { padding-right: 0; display: flex; flex-direction: column; align-items: center; }
      .hero-desc { text-align: center; }
      .hero-photo-frame { width: min(420px, 70vw); }
      .hero-scroll-hint { display: none; }
      section { padding: 6rem 2rem; }
      footer { padding: 3rem 2.5rem; }
      .footer-inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
      .footer-brand { grid-column: 1 / -1; }
      .videos-grid { grid-template-columns: repeat(2, 1fr); }
      .gallery-masonry { columns: 2; }
      .clippings-grid { grid-template-columns: repeat(4, 1fr); }
      .clipping-card:nth-child(1),
      .clipping-card:nth-child(2) { grid-column: span 2; min-height: 360px; }
      .clipping-card:nth-child(3),
      .clipping-card:nth-child(4),
      .clipping-card:nth-child(5) { grid-column: span 2; }
    }
    /* ── GALERIA ── */
    #galeria { background: var(--cream); }
    .galeria-intro {
      font-size: 0.92rem; font-weight: 300; line-height: 1.8;
      color: var(--ink-muted); margin-bottom: 3rem; max-width: 480px;
    }
    .gallery-masonry { columns: 3; column-gap: 0.8rem; }
    .gallery-item {
      break-inside: avoid; margin-bottom: 0.8rem;
      position: relative; overflow: hidden; cursor: zoom-in;
    }
    .gallery-item img {
      width: 100%; display: block;
      filter: brightness(0.9) contrast(1.02);
      transition: transform 0.55s ease, filter 0.4s ease;
    }
    .gallery-item:hover img { transform: scale(1.04); filter: brightness(1) contrast(1.06); }
    .gallery-item-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(14,11,6,0.85) 0%, transparent 55%);
      display: flex; flex-direction: column; justify-content: flex-end; padding: 1rem;
      opacity: 0; transform: translateY(6px);
      transition: opacity 0.35s ease, transform 0.35s ease;
    }
    .gallery-item:hover .gallery-item-overlay { opacity: 1; transform: translateY(0); }
    .gallery-item-cat {
      font-size: 0.58rem; font-weight: 600; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--gold-light); margin-bottom: 0.2rem;
    }
    .gallery-item-label { font-size: 0.78rem; font-weight: 500; color: rgba(240,228,232,0.9); line-height: 1.3; }

    /* ── CLIPPINGS GRID ── */
    .imprensa-intro {
      font-size: 0.92rem; font-weight: 300; line-height: 1.85;
      color: rgba(200,175,130,0.55); margin-bottom: 3rem; max-width: 500px;
    }
    .clippings-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 0.8rem;
    }
    .clipping-card {
      grid-column: span 2;
      position: relative; overflow: hidden; cursor: pointer;
      background: #0a0804;
      border: 1px solid rgba(200,175,100,0.1);
      min-height: 300px;
      transition: border-color 0.4s;
    }
    .clipping-card:nth-child(1),
    .clipping-card:nth-child(2) { grid-column: span 3; min-height: 420px; }
    .clipping-card:hover { border-color: rgba(200,175,100,0.35); }
    .clipping-card img {
      width: 100%; height: 100%; min-height: inherit;
      object-fit: cover; object-position: top; display: block;
      filter: sepia(0.55) contrast(1.05) brightness(0.85);
      transition: transform 0.6s ease, filter 0.4s ease;
    }
    .clipping-card:hover img {
      transform: scale(1.05);
      filter: sepia(0.3) contrast(1.1) brightness(0.95);
    }
    .clipping-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(to top,
        rgba(8,5,2,0.96) 0%, rgba(8,5,2,0.55) 38%, transparent 70%);
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: 1.5rem;
      transform: translateY(4px);
      transition: transform 0.4s ease;
    }
    .clipping-card:hover .clipping-overlay { transform: translateY(0); }
    .clipping-pub {
      font-size: 0.6rem; font-weight: 600; letter-spacing: 0.22em;
      text-transform: uppercase; color: #c9a85c; margin-bottom: 0.25rem;
    }
    .clipping-date {
      font-size: 0.57rem; letter-spacing: 0.1em;
      color: rgba(240,228,232,0.4); margin-bottom: 0.5rem;
    }
    .clipping-headline {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem; font-weight: 700; color: var(--ink); line-height: 1.3;
    }
    .clipping-card:nth-child(1) .clipping-headline,
    .clipping-card:nth-child(2) .clipping-headline { font-size: 1.15rem; }

    /* ── LIGHTBOX ── */
    .lightbox {
      position: fixed; inset: 0; z-index: 1000;
      background: rgba(5,3,1,0.96);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none;
      transition: opacity 0.35s ease;
      backdrop-filter: blur(10px);
    }
    .lightbox.open { opacity: 1; pointer-events: auto; }
    .lightbox-inner {
      position: relative;
      max-width: min(90vw, 700px);
      max-height: 88vh;
      display: flex; align-items: center; justify-content: center;
    }
    .lightbox-img {
      max-width: 100%; max-height: 88vh;
      object-fit: contain; display: block;
      filter: sepia(0.15) contrast(1.05);
      border: 1px solid rgba(200,175,100,0.2);
      box-shadow: 0 32px 90px rgba(0,0,0,0.85);
      transition: opacity 0.2s;
    }
    .lb-btn {
      position: fixed;
      background: rgba(100,36,36,0.75);
      border: 1px solid rgba(201,168,92,0.4);
      color: #fff; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.25s, transform 0.2s;
      z-index: 1001;
    }
    .lb-btn:hover { background: var(--gold); transform: scale(1.08); }
    #lb-close { top: 1.25rem; right: 1.25rem; width: 42px; height: 42px; border-radius: 0; }
    #lb-prev  { top: 50%; left: 1.25rem;  transform: translateY(-50%); width: 46px; height: 46px; }
    #lb-next  { top: 50%; right: 1.25rem; transform: translateY(-50%); width: 46px; height: 46px; }
    #lb-prev:hover { transform: translateY(-50%) scale(1.08); }
    #lb-next:hover { transform: translateY(-50%) scale(1.08); }
    .lb-counter {
      position: fixed; top: 1.35rem; left: 50%;
      transform: translateX(-50%);
      font-size: 0.65rem; letter-spacing: 0.18em;
      color: rgba(240,228,232,0.35); pointer-events: none;
    }
    .lb-caption {
      position: fixed; bottom: 1.5rem; left: 50%;
      transform: translateX(-50%);
      text-align: center; white-space: nowrap;
      background: rgba(8,5,2,0.82);
      padding: 0.6rem 1.8rem;
      backdrop-filter: blur(6px);
      border: 1px solid rgba(200,175,100,0.12);
      pointer-events: none;
    }
    .lb-pub {
      display: block; font-size: 0.6rem; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: #c9a85c; margin-bottom: 0.2rem;
    }
    .lb-title {
      font-family: 'Playfair Display', serif;
      font-size: 0.88rem; color: var(--ink);
    }
    .clipping-card { cursor: zoom-in; }

    /* ── SEPARADORES DE SEÇÃO ── */

    /* linha fina em todas as seções (exceto hero) */
    section:not(#hero) {
      border-top: 1px solid rgba(201,168,92,0.12);
    }

    /* separador ornamental: linha dourada central + diamante */
    section:not(#hero):not(#imprensa) {
      position: relative;
    }
    /* linha dourada que irradia do centro */
    section:not(#hero):not(#imprensa)::before {
      content: '';
      position: absolute;
      top: -1px; left: 20%; right: 20%;
      height: 1px;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(201,168,92,0.4) 20%,
        rgba(201,168,92,0.75) 50%,
        rgba(201,168,92,0.4) 80%,
        transparent 100%
      );
    }
    /* diamante central */
    section:not(#hero):not(#imprensa)::after {
      content: '';
      position: absolute;
      top: -5px; left: 50%;
      transform: translateX(-50%) rotate(45deg);
      width: 8px; height: 8px;
      background: var(--gold);
      box-shadow: 0 0 10px rgba(201,168,92,0.6), 0 0 24px rgba(201,168,92,0.2);
    }

    /* imprensa: borda sépia própria */
    #imprensa { border-top-color: rgba(200,175,100,0.18); }

    /* tom sépia para elementos dentro da imprensa */
    #imprensa .section-tag { color: #c9a85c; }
    #imprensa .section-tag::before { background: #c9a85c; }
    #imprensa .section-title { color: #f0e2c4; }
    #imprensa .section-title em { color: #d4a843; }
    #imprensa .divider { background: #c9a85c; }

    @media (max-width: 768px) {
      #hero { grid-template-columns: 1fr; padding: 7rem 1.5rem 4rem; text-align: center; }
      .hero-bg-ornament { display: none; }
      .hero-content { padding-right: 0; display: flex; flex-direction: column; align-items: center; }
      .hero-desc { text-align: center; }
      .hero-photo-frame { width: min(280px, 75vw); }
      .hero-scroll-hint { display: none; }
      #sobre, #professora { grid-template-columns: 1fr; gap: 3rem; }
      section { padding: 5rem 1.5rem; }
      #imprensa { padding: 5rem 1.5rem; }
      .newspaper-outer { padding: 2rem 1.5rem; }
      .np-spread { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
      .especializacao-grid { grid-template-columns: 1fr; }
      .presenca-grid { grid-template-columns: 1fr; }
      .videos-grid { grid-template-columns: 1fr; }
      .thesmorphoria-highlight { grid-template-columns: 1fr; }
      .gallery-masonry { columns: 2; }
      .clippings-grid { grid-template-columns: 1fr 1fr; gap: 0.6rem; }
      .clipping-card,
      .clipping-card:nth-child(1),
      .clipping-card:nth-child(2) { grid-column: span 1; min-height: 260px; }
      .clipping-card:nth-child(5) { grid-column: span 2; }
      .timeline::before { left: 20px; }
      .timeline-item { grid-template-columns: 40px 1fr; }
      .timeline-item:nth-child(odd) .tl-content,
      .timeline-item:nth-child(even) .tl-content { grid-column: 2; text-align: left; padding-left: 1.5rem; padding-right: 0; }
      .timeline-item:nth-child(odd) .tl-empty,
      .timeline-item:nth-child(even) .tl-empty { display: none; }
      .tl-dot { grid-column: 1; justify-content: flex-start; padding-left: 13px; }
      .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
      .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
      footer { padding: 3rem 1.5rem; }
    }

    /* ── LGPD COOKIE BANNER ── */
    #cookie-banner {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 8000;
      background: rgba(14,11,6,0.97);
      border-top: 1px solid rgba(201,168,92,0.2);
      backdrop-filter: blur(12px);
      padding: 1rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1.5rem; flex-wrap: wrap;
      transform: translateY(100%);
      transition: transform 0.5s cubic-bezier(0.4,0,0.2,1);
    }
    #cookie-banner.visible { transform: translateY(0); }
    .cookie-text {
      font-size: 0.78rem; font-weight: 300; color: var(--ink-soft);
      line-height: 1.6; flex: 1; min-width: 200px;
    }
    .cookie-text a { color: var(--gold); text-decoration: underline; }
    .cookie-btns { display: flex; gap: 0.75rem; flex-shrink: 0; }
    .cookie-accept {
      padding: 0.5rem 1.2rem; background: var(--gold-dark);
      color: var(--ink); border: none; cursor: pointer;
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em;
      text-transform: uppercase; transition: background 0.25s;
    }
    .cookie-accept:hover { background: var(--gold); }
    .cookie-decline {
      padding: 0.5rem 1rem; background: transparent;
      color: var(--ink-muted); border: 1px solid rgba(201,168,92,0.2);
      cursor: pointer; font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.25s, border-color 0.25s;
    }
    .cookie-decline:hover { color: var(--ink-soft); border-color: rgba(201,168,92,0.4); }

    /* ── SHARE BUTTON ── */
    #share-btn {
      position: fixed; bottom: 2rem; left: 2rem; z-index: 140;
      width: 44px; height: 44px; border-radius: 50%;
      background: rgba(14,11,6,0.9);
      border: 1px solid rgba(201,168,92,0.35);
      color: var(--gold); cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      backdrop-filter: blur(8px);
      transition: background 0.25s, border-color 0.25s, transform 0.25s;
      opacity: 0; pointer-events: none;
    }
    #share-btn.visible { opacity: 1; pointer-events: auto; }
    #share-btn:hover { background: rgba(201,168,92,0.12); border-color: var(--gold); transform: scale(1.08); }

    /* share tooltip */
    #share-btn::after {
      content: 'Compartilhar';
      position: absolute; left: 54px; top: 50%; transform: translateY(-50%);
      white-space: nowrap; font-size: 0.68rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--gold); background: rgba(14,11,6,0.9);
      border: 1px solid rgba(201,168,92,0.25);
      padding: 0.3rem 0.7rem; border-radius: 2px;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s;
    }
    #share-btn:hover::after { opacity: 1; }

    /* ── LOADING SCREEN ── */
    #loading-screen {
      position: fixed; inset: 0; z-index: 9999;
      background: var(--cream);
      display: flex; align-items: center; justify-content: center;
      transition: opacity 0.7s ease, visibility 0.7s ease;
    }
    #loading-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }

    .ls-inner {
      display: flex; flex-direction: column; align-items: center;
      text-align: center; gap: 0;
    }
    .ls-line-top {
      width: 1px; height: 0; background: var(--gold);
      animation: ls-grow-line 0.9s ease forwards 0.1s;
      margin-bottom: 1.8rem;
    }
    @keyframes ls-grow-line { to { height: 60px; } }

    .ls-tag {
      font-size: 0.65rem; font-weight: 600; letter-spacing: 0.3em;
      text-transform: uppercase; color: var(--gold);
      opacity: 0; animation: ls-fade-up 0.6s ease forwards 0.7s;
      margin-bottom: 1.4rem;
    }
    .ls-name {
      font-family: 'Playfair Display', serif;
      font-size: clamp(3rem, 8vw, 5.5rem);
      font-weight: 700; line-height: 1.05;
      color: var(--ink); letter-spacing: -0.01em;
      opacity: 0; animation: ls-fade-up 0.8s ease forwards 0.95s;
      margin-bottom: 1.6rem;
    }
    .ls-name em { color: var(--gold); font-style: italic; display: block; }

    .ls-ornament {
      display: flex; align-items: center; gap: 0.8rem;
      opacity: 0; animation: ls-fade-up 0.6s ease forwards 1.3s;
      margin-bottom: 2.4rem;
    }
    .ls-ornament span {
      display: block; width: 40px; height: 1px; background: rgba(201,168,92,0.4);
    }
    .ls-diamond { font-size: 0.5rem; color: var(--gold); }

    .ls-bar-track {
      width: 160px; height: 1px; background: rgba(201,168,92,0.15);
      overflow: hidden;
      opacity: 0; animation: ls-fade-up 0.5s ease forwards 1.5s;
    }
    .ls-bar-fill {
      height: 100%; width: 0; background: var(--gold);
      animation: ls-bar 1.2s cubic-bezier(0.4,0,0.2,1) forwards 1.6s;
    }
    @keyframes ls-bar { to { width: 100%; } }
    @keyframes ls-fade-up {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

  <!-- LOADING SCREEN -->
  <div id="loading-screen" aria-hidden="true">
    <div class="ls-inner">
      <div class="ls-line-top"></div>
      <p class="ls-tag">Ordem do Templo de Ísis</p>
      <h1 class="ls-name">Soraya<br><em>Magalla</em></h1>
      <div class="ls-ornament">
        <span></span><span class="ls-diamond">◆</span><span></span>
      </div>
      <div class="ls-bar-track"><div class="ls-bar-fill"></div></div>
    </div>
  </div>

  <!-- LGPD COOKIE BANNER -->
  <div id="cookie-banner" role="dialog" aria-label="Aviso de privacidade">
    <p class="cookie-text">
      Este site utiliza cookies essenciais para funcionamento e análise de visitas.
      Ao continuar, você concorda com nossa política de privacidade em conformidade com a <strong>LGPD</strong>.
    </p>
    <div class="cookie-btns">
      <button class="cookie-decline" id="cookie-decline">Recusar</button>
      <button class="cookie-accept" id="cookie-accept">Aceitar</button>
    </div>
  </div>

  <!-- SHARE BUTTON -->
  <button id="share-btn" aria-label="Compartilhar este site">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
    </svg>
  </button>

  <!-- PROGRESS BAR -->
  <div id="progress-bar"></div>

  <!-- BACK TO TOP -->
  <button id="back-to-top" aria-label="Voltar ao topo">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <!-- MOBILE NAV OVERLAY -->
  <div class="nav-overlay" id="nav-overlay">
    <a href="#sobre"         class="overlay-link" data-i18n="nav.perfil">Perfil</a>
    <a href="#formacao"      class="overlay-link" data-i18n="nav.formacao">Formação</a>
    <a href="#especializacao" class="overlay-link" data-i18n="nav.arte">Arte</a>
    <a href="#professora"    class="overlay-link" data-i18n="nav.ensino">Ensino</a>
    <a href="#imprensa"      class="overlay-link" data-i18n="nav.imprensa">Imprensa</a>
    <a href="#presenca"      class="overlay-link" data-i18n="nav.presenca">Presença</a>
    <a href="#galeria"       class="overlay-link" data-i18n="nav.galeria">Galeria</a>
    <a href="#entrevistas"   class="overlay-link" data-i18n="nav.entrevistas">Entrevistas</a>
    <div class="overlay-lang">
      <button class="lang-btn active" data-lang="pt">PT</button>
      <button class="lang-btn" data-lang="en">EN</button>
      <button class="lang-btn" data-lang="es">ES</button>
    </div>
  </div>

  <!-- NAV -->
  <nav id="navbar">
    <a href="#hero" class="nav-logo">Soraya <span>Magalla</span></a>
    <ul class="nav-links">
      <li><a href="#sobre"          data-i18n="nav.perfil">Perfil</a></li>
      <li><a href="#formacao"       data-i18n="nav.formacao">Formação</a></li>
      <li><a href="#especializacao" data-i18n="nav.arte">Arte</a></li>
      <li><a href="#professora"     data-i18n="nav.ensino">Ensino</a></li>
      <li><a href="#imprensa"       data-i18n="nav.imprensa">Imprensa</a></li>
      <li><a href="#presenca"       data-i18n="nav.presenca">Presença</a></li>
      <li><a href="#galeria"        data-i18n="nav.galeria">Galeria</a></li>
      <li><a href="#entrevistas"    data-i18n="nav.entrevistas">Entrevistas</a></li>
    </ul>
    <button id="animation-toggle" class="animation-toggle" type="button" aria-pressed="false" title="Alternar animações">Animações</button>
    <div class="lang-switcher" aria-label="Idioma">
      <button class="lang-btn active" data-lang="pt">PT</button>
      <span class="lang-sep">|</span>
      <button class="lang-btn" data-lang="en">EN</button>
      <span class="lang-sep">|</span>
      <button class="lang-btn" data-lang="es">ES</button>
    </div>
    <button class="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- HERO -->
  <section id="hero">
    <div class="hero-bg-ornament"></div>
    <div class="hero-content">
      <div class="hero-tagline" data-i18n="hero.tagline">Marechal Deodoro · Alagoas · Brasil</div>
      <h1 class="hero-name">
        Soraya<br>
        <span class="accent">Magalla</span>
      </h1>
      <p class="hero-subtitle" data-i18n="hero.subtitle">Bailarina · Coreógrafa · Professora</p>
      <p class="hero-desc" data-i18n="hero.desc">
        Alagoana reconhecida como uma das pioneiras da dança árabe no Nordeste do Brasil.
        Décadas dedicadas à arte oriental, à formação de bailarinas e à preservação
        da cultura egípcia através do movimento e da espiritualidade.
      </p>
      <a href="#sobre" class="hero-cta">
        <span data-i18n="hero.cta">Conhecer o perfil</span> <span class="arrow">→</span>
      </a>
    </div>
    <div class="hero-visual">
      <div class="hero-photo-frame">
        <div class="frame-border"></div>
        <div class="frame-border-2"></div>
        <div class="hero-photo">
          <img src="Imagens%20Soraya%20Magalla/ChatGPT%20Image%2015%20de%20mai.%20de%202026%2C%2016_08_14.png"
               alt="Soraya Magalla"
               loading="eager"
               fetchpriority="high"
               decoding="sync">
        </div>
        <div class="hero-badge">
          <div class="year">30+</div>
          <div class="badge-text" data-i18n="hero.badge">Anos de<br>Arte</div>
        </div>
      </div>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
      <div class="scroll-line"></div>
      <span data-i18n="hero.scroll">Role para descobrir</span>
    </div>
  </section>

  <!-- PERFIL -->
  <section id="sobre">
    <div class="sobre-text fade-in">
      <div class="section-tag" data-i18n="nav.perfil">Perfil</div>
      <h2 class="section-title" data-i18n="sobre.title">Pioneira da dança<br>árabe no <em>Nordeste</em></h2>
      <div class="divider"></div>
      <p data-i18n="sobre.p1"><strong>Soraya Magalla</strong> é bailarina, coreógrafa e professora alagoana reconhecida por sua trajetória na dança árabe no Brasil, especialmente no Nordeste. Considerada por alunos e admiradores como uma das pioneiras da dança do ventre na região.</p>
      <p data-i18n="sobre.p2">Ao longo de décadas, atuou na <em>formação de bailarinas</em> e na divulgação da cultura oriental, ministrando cursos, workshops e apresentações em diversas cidades brasileiras — de Alagoas ao Paraná.</p>
      <div class="sobre-quote">
        <p data-i18n="sobre.quote">"Coreógrafa Egyptian Ballet, Danças Árabes e Flamenco"</p>
        <cite data-i18n="sobre.cite">— Soraya Magalla, Instagram</cite>
      </div>
      <p data-i18n="sobre.p3">Seu trabalho vai além do palco: ela pesquisou, documentou e ensinou, garantindo que a riqueza cultural da dança oriental floresça e evolua nas terras nordestinas. Uma <em>guardiã de uma tradição</em> milenar.</p>
    </div>
    <div class="stats-grid fade-in fade-in-delay-2">
      <div class="stat-card">
        <div class="stat-number">30+</div>
        <div class="stat-label" data-i18n="stat.career">Anos de<br>carreira</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">3</div>
        <div class="stat-label" data-i18n="stat.styles">Estilos de<br>dança</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">AL</div>
        <div class="stat-label" data-i18n="stat.pioneer">Pioneira em<br>Alagoas</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">NE</div>
        <div class="stat-label" data-i18n="stat.reference">Referência no<br>Nordeste</div>
      </div>
    </div>
  </section>

  <!-- FORMAÇÃO -->
  <section id="formacao">
    <div class="timeline-header fade-in">
      <div class="section-tag" data-i18n="nav.formacao">Formação</div>
      <h2 class="section-title" data-i18n="formacao.title">Uma trajetória de<br><em>descobertas</em> e arte</h2>
      <div class="divider"></div>
    </div>
    <div class="timeline">
      <div class="timeline-item">
        <div class="tl-content">
          <div class="tl-year">Início</div>
          <div class="tl-title" data-i18n="tl.1.title">Escola Eliana Cavalcanti</div>
          <div class="tl-desc" data-i18n="tl.1.desc">Soraya iniciou sua formação no balé clássico na escola de dança Eliana Cavalcanti, onde desenvolveu as bases técnicas do movimento e despertou sua paixão pela expressão corporal.</div>
        </div>
        <div class="tl-dot"><div class="tl-dot-inner"></div></div>
        <div class="tl-empty"></div>
      </div>
      <div class="timeline-item">
        <div class="tl-empty"></div>
        <div class="tl-dot"><div class="tl-dot-inner"></div></div>
        <div class="tl-content">
          <div class="tl-year">CENART</div>
          <div class="tl-title" data-i18n="tl.2.title">Aprofundamento técnico</div>
          <div class="tl-desc" data-i18n="tl.2.desc">Estudou no CENART, em Alagoas, aprofundando seus conhecimentos técnicos e artísticos — passo fundamental na construção de sua identidade como artista.</div>
        </div>
      </div>
      <div class="timeline-item">
        <div class="tl-content">
          <div class="tl-year">Recife</div>
          <div class="tl-title" data-i18n="tl.3.title">A grande descoberta</div>
          <div class="tl-desc" data-i18n="tl.3.desc">Durante um ciclo de dança no Teatro Santa Isabel, em Recife, foi descoberta pela renomada coreógrafa polonesa Halina Biernacka — um encontro que mudaria o rumo de sua carreira para sempre.</div>
        </div>
        <div class="tl-dot"><div class="tl-dot-inner"></div></div>
        <div class="tl-empty"></div>
      </div>
      <div class="timeline-item">
        <div class="tl-empty"></div>
        <div class="tl-dot"><div class="tl-dot-inner"></div></div>
        <div class="tl-content">
          <div class="tl-year">São Paulo</div>
          <div class="tl-title" data-i18n="tl.4.title">Escola Madeleine Shahrazed</div>
          <div class="tl-desc" data-i18n="tl.4.desc">O reconhecimento abriu portas para São Paulo, onde Soraya estudou na tradicional escola de dança árabe da Madeleine Sharazed — consolidando sua especialização na arte oriental.</div>
        </div>
      </div>
      <div class="timeline-item">
        <div class="tl-content">
          <div class="tl-year">Grécia</div>
          <div class="tl-title" data-i18n="tl.5.title">Expansão internacional</div>
          <div class="tl-desc" data-i18n="tl.5.desc">Após São Paulo, Soraya levou a dança para além do território nacional, apresentando e estudando em festivais e residências na Grécia — aproximando seu trabalho do circuito internacional.</div>
        </div>
        <div class="tl-dot"><div class="tl-dot-inner"></div></div>
        <div class="tl-empty"></div>
      </div>
      <div class="timeline-item">
        <div class="tl-empty"></div>
        <div class="tl-dot"><div class="tl-dot-inner"></div></div>
        <div class="tl-content">
          <div class="tl-year">Madrid</div>
          <div class="tl-title" data-i18n="tl.6.title">Flamenco em Madrid</div>
          <div class="tl-desc" data-i18n="tl.6.desc">Recentemente cursou flamenco em Madrid, ampliando ainda mais sua paleta de dança e fundindo a sensibilidade espanhola com sua base oriental.</div>
        </div>
      </div>
      <div class="timeline-item">
        <div class="tl-content">
          <div class="tl-year">Hoje</div>
          <div class="tl-title" data-i18n="tl.7.title">Legado vivo</div>
          <div class="tl-desc" data-i18n="tl.7.desc">Com décadas de estrada, Soraya retornou ao Nordeste para semear o que aprendeu, formando gerações de bailarinas e tornando Alagoas um polo de referência na dança oriental brasileira.</div>
        </div>
        <div class="tl-dot"><div class="tl-dot-inner"></div></div>
        <div class="tl-empty"></div>
      </div>
    </div>
  </section>

  <!-- ESPECIALIZAÇÃO -->
  <section id="especializacao">
    <div class="especializacao-header fade-in">
      <div class="section-tag" data-i18n="nav.arte">Especialização</div>
      <h2 class="section-title" data-i18n="espec.title">As <em>artes</em> que<br>definem Soraya</h2>
      <div class="divider"></div>
      <p class="especializacao-intro" data-i18n="espec.intro">Mais do que uma dançarina, Soraya é uma artista multifacetada. Seu trabalho mistura tradição, teatro, espiritualidade e técnica — criando uma linguagem própria e única.</p>
    </div>
    <div class="especializacao-grid fade-in fade-in-delay-1">
      <div class="spec-card">
        <div class="spec-number">01</div>
        <div class="spec-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
        </div>
        <div class="spec-title">Egyptian Ballet</div>
        <div class="spec-desc" data-i18n="spec.1.desc">Fusão única entre ballet clássico e movimentos da dança egípcia. Soraya desenvolveu apresentações que unem a precisão técnica do balé à expressividade e ancestralidade da arte do Egito antigo.</div>
      </div>
      <div class="spec-card">
        <div class="spec-number">02</div>
        <div class="spec-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="8" r="4"/><path d="M6 20v-2a6 6 0 0 1 12 0v2"/>
          </svg>
        </div>
        <div class="spec-title">Dança do Ventre</div>
        <div class="spec-desc" data-i18n="spec.2.desc">Arte milenar com raízes no antigo Egito, a dança do ventre é o coração do trabalho de Soraya. Ela explora seus aspectos terapêuticos, espirituais e femininos, além da técnica tradicional.</div>
      </div>
      <div class="spec-card">
        <div class="spec-number">03</div>
        <div class="spec-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
          </svg>
        </div>
        <div class="spec-title">Flamenco</div>
        <div class="spec-desc" data-i18n="spec.3.desc">A paixão espanhola encontra a alma árabe. O flamenco compõe a paleta artística de Soraya como extensão natural de sua busca pela expressão corporal mais intensa e dramática.</div>
      </div>
      <div class="spec-card">
        <div class="spec-number">04</div>
        <div class="spec-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </div>
        <div class="spec-title">Sagrado Feminino</div>
        <div class="spec-desc" data-i18n="spec.4.desc">A conexão entre movimento e espiritualidade feminina. Soraya incorpora em seu trabalho uma visão da dança como ritual, cura e autoconhecimento — transformando o palco em espaço sagrado.</div>
      </div>
    </div>
  </section>

  <!-- PROFESSORA -->
  <section id="professora">
    <div class="professora-text fade-in">
      <div class="section-tag" data-i18n="nav.ensino">Ensino</div>
      <h2 class="section-title" data-i18n="prof.title">Formando novas<br><em>gerações</em></h2>
      <div class="divider"></div>
      <p data-i18n="prof.p1"><strong>Soraya Magalla</strong> dedicou grande parte de sua carreira ao ensino. Ficou conhecida pela formação de novas bailarinas e pela valorização da cultura árabe no Nordeste.</p>
      <p data-i18n="prof.p2">Ela ministrou <em>cursos, workshops e apresentações</em> em diferentes cidades brasileiras, levando a arte oriental para onde quer que fosse — de Alagoas até o interior do Paraná.</p>
      <div class="quote-box">
        <p data-i18n="prof.quote">"A dança tem sido utilizada como forma de terapia capaz de superar e fortalecer a autoestima da mulher, contribuindo para o equilíbrio físico e emocional."</p>
      </div>
      <ul class="atuacao-list">
        <li data-i18n="prof.li1">Cursos e workshops em múltiplas cidades brasileiras</li>
        <li data-i18n="prof.li2">Formação de bailarinas que atuam em todo o Nordeste</li>
        <li data-i18n="prof.li3">Valorização da cultura árabe e oriental na região</li>
        <li data-i18n="prof.li4">Apresentações com foco terapêutico e espiritual</li>
        <li data-i18n="prof.li5">Projetos ligados ao sagrado feminino e cultura oriental</li>
      </ul>
    </div>
